# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Reference material kept locally only — do not commit; use git-lfs if needed
*.pdf

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
.env*.local

# IntelliJ
/.idea/
.claude/

# git worktrees
.worktrees/

# Local DB snapshots (pg_dump custom format)
/.snapshots/

# Generated Ollama Modelfiles (Plan D — pnpm build-local-models)
/.ollama/

# Dev server log (Plan D smoke testing — `pnpm dev:log` writes here)
/.dev.log

# Brainstorming companion sessions
.superpowers/

# clerk configuration (can include secrets)
/.clerk/
