# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Reference material kept locally only — do not commit; use git-lfs if needed
*.pdf

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
.env*.local

# IntelliJ
/.idea/
.claude/*
# Project-shared skills (auto-loaded in build sessions) — whitelisted for git
!.claude/skills/
.claude/skills/*
!.claude/skills/spike-findings-*/

# git worktrees
.worktrees/

# Local DB snapshots (pg_dump custom format)
/.snapshots/

# Campaign data — REQ-007 mandates this lives OUTSIDE the codebase repo.
# Default location is ~/.dnd-ai-master/vault/campaigns/ (home-based, not here),
# but if a developer sets VAULT_CAMPAIGNS_ROOT to a project-relative path
# (e.g. ./local/vault-campaigns/), these patterns prevent accidental commits.
/local/
/vault-campaigns/
/data/vault/campaigns/

# Generated Ollama Modelfiles (Plan D — pnpm build-local-models)
/.ollama/

# Dev server log (Plan D smoke testing — `pnpm dev:log` writes here)
/.dev.log

# Brainstorming companion sessions
.superpowers/

# clerk configuration (can include secrets)
/.clerk/
