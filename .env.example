# Postgres / Neon connection string
DATABASE_URL=postgres://user:password@host:5432/dnd_ai_master

# Optional: separate URL for tests
TEST_DATABASE_URL=postgres://user:password@host:5432/dnd_ai_master_test

# Anthropic — not used in Plan A, added now to keep .env.example complete
ANTHROPIC_API_KEY=

# Master AI models (override defaults if needed)
# Leave empty to use the latest 4-5 alias defaults set in src/ai/master/anthropic-client.ts.
# Set to a dated snapshot ID for reproducibility (e.g. claude-sonnet-4-5-20251015).
ANTHROPIC_MASTER_MODEL=
ANTHROPIC_LANGUAGE_MODEL=

# Clerk auth (https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
