    "@vercel/functions": "^3.5.0",
    "csv-parse": "^6.2.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.4",
    "openai": "^6.35.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4.2.4",
