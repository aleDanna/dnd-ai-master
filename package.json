{
  "name": "dnd-ai-master",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:log": "next dev --turbopack 2>&1 | tee .dev.log",
    "build": "tsx src/db/migrate.ts && next build",
    "build:no-migrate": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:fork-legacy": "tsx scripts/migrate-legacy-template-sessions.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/srd/seed.ts",
    "db:reseed": "tsx src/srd/seed.ts --reset",
    "db:audit": "tsx scripts/db-audit.ts",
    "db:cleanup": "tsx scripts/db-cleanup.ts",
    "db:vacuum": "tsx scripts/db-vacuum.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:snapshot": "tsx scripts/db-snapshot.ts",
    "db:restore": "tsx scripts/db-restore.ts",
    "build-local-models": "tsx scripts/build-local-models.ts",
    "build-rag-index": "tsx scripts/build-rag-index.ts",
    "migrate-handbook-to-vault": "tsx scripts/migrate-handbook-to-vault.ts",
    "migrate-campaigns-to-vault": "tsx scripts/migrate-campaigns-to-vault.ts",
    "bench-vault-m4": "tsx scripts/bench-vault-m4.ts",
    "vault:flip": "tsx scripts/vault-flip.ts",
    "vault:backup": "tsx scripts/vault-backup.ts",
    "vault:rebuild-views": "tsx scripts/vault-rebuild-views.ts",
    "tunnel:proxy": "tsx scripts/tunnel-proxy.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@clerk/nextjs": "^7.3.0",
    "@google/genai": "^1.52.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@vercel/config": "^0.3.0",
    "@vercel/functions": "^3.5.0",
    "csv-parse": "^6.2.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.4",
    "openai": "^6.35.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4.2.4",
    "vaul": "^1.1.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
