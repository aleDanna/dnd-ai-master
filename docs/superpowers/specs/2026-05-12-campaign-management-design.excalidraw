      "seed": 130006,
      "version": 1,
      "versionNonce": 230006,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1715539200000,
      "link": null,
      "locked": false,
      "text": "PR 1 — 0024_campaigns.sql\n\nStep A — DDL: create campaigns + columns\nStep B — Backfill (temp-table, 1 campaign per session)\nStep B-bis — Legacy template fork (TS script)\nStep C — ALTER campaign_id SET NOT NULL\n\nApp switch (same PR):\n• master loop reads premise/lang/tone from campaigns\n• set_tonal_frame / engagement_profile → campaigns\n• POST /api/sessions → 410 Gone\n• /sessions, /sessions/new → 301 redirect",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 12,
      "containerId": "box-pr1",
      "originalText": "PR 1 — 0024_campaigns.sql\n\nStep A — DDL: create campaigns + columns\nStep B — Backfill (temp-table, 1 campaign per session)\nStep B-bis — Legacy template fork (TS script)\nStep C — ALTER campaign_id SET NOT NULL\n\nApp switch (same PR):\n• master loop reads premise/lang/tone from campaigns\n• set_tonal_frame / engagement_profile → campaigns\n• POST /api/sessions → 410 Gone\n• /sessions, /sessions/new → 301 redirect",
      "lineHeight": 1.25
    },
