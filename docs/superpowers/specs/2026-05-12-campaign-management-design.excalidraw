    {
      "id": "text-pr1",
      "type": "text",
      "x": 100,
      "y": 950,
      "width": 600,
      "height": 240,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
